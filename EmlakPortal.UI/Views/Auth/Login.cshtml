@{
    Layout = null; // Giriş sayfasında sidebar olmasın diye layout'u kapattık
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <title>Giriş Yap - Emlak Portalı</title>
    <link href="~/vendor/fontawesome-free/css/all.min.css" rel="stylesheet">
    <link href="~/css/sb-admin-2.min.css" rel="stylesheet">
</head>
<body class="bg-gradient-primary">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-xl-5 col-lg-6 col-md-9">
                <div class="card o-hidden border-0 shadow-lg my-5">
                    <div class="card-body p-0">
                        <div class="p-5">
                            <div class="text-center">
                                <h1 class="h4 text-gray-900 mb-4">Hoş Geldiniz!</h1>
                            </div>
                            <form id="loginForm">
                                <div class="form-group">
                                    <input type="text" id="username" class="form-control form-control-user" placeholder="Kullanıcı Adı" required>
                                </div>
                                <div class="form-group">
                                    <input type="password" id="password" class="form-control form-control-user" placeholder="Şifre" required>
                                </div>
                                <button type="submit" class="btn btn-primary btn-user btn-block">Giriş Yap</button>
                            </form>
                            <hr>
                            <div class="text-center">
                                <a class="small" href="/Auth/Register">Yeni Hesap Oluştur!</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/vendor/jquery/jquery.min.js"></script>
    <script>
        $("#loginForm").submit(function (e) {
            e.preventDefault();
            var loginData = {
                username: $("#username").val(),
                password: $("#password").val()
            };

            $.ajax({
                url: "http://localhost:5155/api/Auth/Login",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(loginData),
                success: function (response) {
                    // API'den dönen token'ı kaydet
                    localStorage.setItem("token", response.token);
                    alert("Giriş başarılı! Panale yönlendiriliyorsunuz.");
                    window.location.href = "/Home/Index";
                },
                error: function () {
                    alert("Kullanıcı adı veya şifre hatalı!");
                }
            });
        });
    </script>
</body>
</html>