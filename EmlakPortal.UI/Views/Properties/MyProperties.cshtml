@{
    ViewData["Title"] = "İlanlarımı Yönet";
    Layout = "_Layout";
}

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">Eklediğim İlanlar</h6>
        <a href="/Properties/Create" class="btn btn-sm btn-success"><i class="fas fa-plus"></i> Yeni İlan Ekle</a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>Başlık</th>
                        <th>Durum</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody id="myPropertiesList">
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            loadMyProperties();

            function loadMyProperties() {
                var token = localStorage.getItem("token");
                $.ajax({
                    url: "http://localhost:5155/api/Properties/MyProperties",
                    type: "GET",
                    beforeSend: function (xhr) {
                        xhr.setRequestHeader("Authorization", "Bearer " + token);
                    },
                    success: function (data) {
                        var html = "";

                        if (!data || data.length === 0) {
                             html = `<tr><td colspan="3" class="text-center text-muted py-4">Henüz eklediğiniz bir ilan bulunmuyor.</td></tr>`;
                        } else {
                            $.each(data, function (index, item) {
                                html += `<tr>
                                            <td class="align-middle font-weight-bold">${item.title}</td>
                                            <td class="align-middle"><span class="badge badge-success px-2 py-1">${item.statusName}</span></td>
                                            <td class="align-middle">
                                                <a href="/Properties/Edit/${item.propertyId}" class="btn btn-warning btn-sm mr-2 shadow-sm">
                                                    <i class="fas fa-edit"></i> Düzenle
                                                </a>
                                                <button onclick="deleteProperty(${item.propertyId})" class="btn btn-danger btn-sm shadow-sm">
                                                    <i class="fas fa-trash"></i> Sil
                                                </button>
                                            </td>
                                        </tr>`;
                            });
                        }
                        $("#myPropertiesList").html(html);
                    },
                    error: function() {
                        Toast.fire({
                            icon: 'error',
                            title: 'Hata',
                            text: 'İlanlarınız yüklenirken bir hata oluştu.'
                        });
                    }
                });
            }
        });

        function deleteProperty(id) {
            Swal.fire({
                title: 'Emin misiniz?',
                text: "Bu ilanı sildiğinizde geri alamazsınız!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#858796',
                confirmButtonText: '<i class="fas fa-trash"></i> Evet, Sil!',
                cancelButtonText: 'Vazgeç'
            }).then((result) => {
                if (result.isConfirmed) {
                    var token = localStorage.getItem("token");

                    $.ajax({
                        url: "http://localhost:5155/api/Properties/" + id,
                        type: "DELETE",
                        beforeSend: function (xhr) {
                            xhr.setRequestHeader("Authorization", "Bearer " + token);
                        },
                        success: function () {
                            Swal.fire(
                                'Silindi!',
                                'İlanınız başarıyla kaldırıldı.',
                                'success'
                            );

                            setTimeout(() => {
                                location.reload();
                            }, 1500);
                        },
                        error: function () {
                            Toast.fire({
                                icon: 'error',
                                title: 'İşlem Başarısız',
                                text: 'İlan silinirken bir sorun oluştu.'
                            });
                        }
                    });
                }
            });
        }
    </script>
}