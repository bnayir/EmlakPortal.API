@{
    ViewData["Title"] = "İlanı Düzenle";
    Layout = "_Layout";
}

<div class="container-fluid">
    <h1 class="h3 mb-4 text-gray-800">İlanı Düzenle</h1>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow mb-4">
                <div class="card-body">
                    <form id="editPropertyForm">
                        <input type="hidden" id="propertyId" value="@ViewBag.PropertyId" />

                        <div class="row">
                            <div class="col-md-8">
                                <div class="form-group">
                                    <label class="font-weight-bold">İlan Başlığı</label>
                                    <input type="text" class="form-control" id="title" required="required">
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label class="font-weight-bold">Fiyat (TL)</label>
                                    <input type="number" class="form-control" id="price" required="required">
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label class="font-weight-bold">Kategori</label>
                                    <select class="form-control" id="category">
                                        <option value="2">Satılık</option>
                                        <option value="1">Kiralık</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label class="font-weight-bold">Emlak Tipi</label>
                                    <select class="form-control" id="propertyType">
                                        <option value="Daire">Daire</option>
                                        <option value="Villa">Villa</option>
                                        <option value="Müstakil Ev">Müstakil Ev</option>
                                        <option value="Rezidans">Rezidans</option>
                                        <option value="Yazlık">Yazlık</option>
                                        <option value="Dubleks">Dubleks</option>
                                        <option value="Tripleks">Tripleks</option>
                                        <option value="Loft">Loft</option>
                                        <option value="Tiny House">Tiny House</option>
                                        <option value="Köşk / Yalı">Köşk / Yalı</option>

                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label class="font-weight-bold">Şehir</label>
                                    <select class="form-control" id="city">
                                        <option value="3">Antalya</option>
                                        <option value="1">İstanbul</option>
                                        <option value="2">Ankara</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label class="font-weight-bold">İlçe</label>
                                    <select class="form-control" id="district">
                                        <option value="1">Muratpaşa</option>
                                        <option value="2">Kepez</option>
                                        <option value="3">Konyaaltı</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label class="font-weight-bold">Metrekare</label>
                                    <input type="number" class="form-control" id="squareMeter" required="required">
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label class="font-weight-bold">Oda Sayısı</label>
                                    <select class="form-control" id="roomCount">
                                        <option value="1+0">1+0 (Stüdyo)</option>
                                        <option value="1+1">1+1</option>
                                        <option value="2+1">2+1</option>
                                        <option value="3+1">3+1</option>
                                        <option value="4+1">4+1 ve Üzeri</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label class="font-weight-bold">Bina Katı</label>
                                    <input type="number" class="form-control" id="floorsCount" required="required">
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label class="font-weight-bold">Bulunduğu Kat</label>
                                    <input type="text" class="form-control" id="floorLocation" required="required">
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label class="font-weight-bold">Isıtma</label>
                                    <select class="form-control" id="heating">
                                        <option value="Klima">Klima</option>
                                        <option value="Doğalgaz">Doğalgaz</option>
                                        <option value="Merkezi">Merkezi</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="font-weight-bold">Açıklama</label>
                            <textarea class="form-control" id="description" rows="5"></textarea>
                        </div>

                        <button type="submit" class="btn btn-warning btn-block shadow-sm">
                            <i class="fas fa-save"></i> Değişiklikleri Kaydet
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const apiBaseUrl = "http://localhost:5155/api";
        const token = localStorage.getItem("token");
        const propertyId = $("#propertyId").val(); 

        $(document).ready(function () {
            $.ajax({
                url: apiBaseUrl + "/Properties/" + propertyId,
                type: "GET",
                success: function (data) {
                    $("#title").val(data.title);
                    $("#price").val(data.price);
                    $("#category").val(data.categoryId);
                    $("#propertyType").val(data.propertyType);
                    $("#city").val(data.cityId);
                    $("#district").val(data.districtId);
                    $("#squareMeter").val(data.squareMeter);
                    $("#roomCount").val(data.roomCount);
                    $("#floorsCount").val(data.floorsCount);
                    $("#floorLocation").val(data.floorLocation);
                    $("#heating").val(data.heating);
                    $("#description").val(data.description);
                },
                error: function () {
                    alert("İlan bilgileri getirilemedi.");
                }
            });

            $("#editPropertyForm").on("submit", function (e) {
                e.preventDefault();

                const updateData = {
                    "PropertyId": parseInt(propertyId), 
                    "Title": $("#title").val().trim(),
                    "Description": $("#description").val().trim(),
                    "Price": parseFloat($("#price").val()),
                    "CityId": parseInt($("#city").val()),
                    "DistrictId": parseInt($("#district").val()),
                    "CategoryId": parseInt($("#category").val()),
                    "SquareMeter": parseInt($("#squareMeter").val()),
                    "RoomCount": $("#roomCount").val(),
                    "PropertyType": $("#propertyType").val(),
                    "FloorsCount": $("#floorsCount").val(),
                    "FloorLocation": $("#floorLocation").val(),
                    "Heating": $("#heating").val()
                };

                $.ajax({
                    url: apiBaseUrl + "/Properties",
                    type: "PUT", 
                    contentType: "application/json",
                    data: JSON.stringify(updateData),
                    headers: {
                        "Authorization": "Bearer " + token
                    },
                    success: function () {
                        alert("İlan başarıyla güncellendi!");
                        window.location.href = "/Admin/Index"; 
                    },
                    error: function (xhr) {
                        alert("Hata: " + xhr.responseText);
                    }
                });
            });
        });
    </script>
}