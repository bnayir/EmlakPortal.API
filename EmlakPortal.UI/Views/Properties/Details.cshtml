@{
    ViewData["Title"] = "İlan Detayı";
    Layout = "_UserLayout";
}

<div class="container mt-5 mb-5" id="detailContainer">
    <div class="text-center py-5" id="loadingSpinner">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;"></div>
        <h5 class="mt-3 text-muted">İlan detayları yükleniyor...</h5>
    </div>
</div>

<div class="modal fade" id="messageModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="fas fa-paper-plane"></i> Satıcıya Mesaj Gönder</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Kapat">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body p-4">
                <textarea id="msgContent" class="form-control" rows="5" placeholder="İlan hakkında sormak istediklerinizi yazın..."></textarea>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">İptal</button>
                <button type="button" onclick="submitMessage()" class="btn btn-success px-4"><i class="fas fa-check"></i> Mesajı Gönder</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const apiBaseUrl = "http://localhost:5155/api";
        const propertyId = window.location.pathname.split('/').pop();
        const token = localStorage.getItem("token");
        let propertyOwnerId = "";

        $(document).ready(function () {
            $.ajax({
                url: apiBaseUrl + "/Properties/" + propertyId,
                type: "GET",
                success: function (data) {
                    propertyOwnerId = data.appUserId;
                    renderDetails(data);
                },
                error: function () {
                    $("#detailContainer").html(`<div class="alert alert-danger text-center shadow-sm"><h4><i class="fas fa-exclamation-triangle"></i> İlan bulunamadı veya silinmiş olabilir.</h4></div>`);
                }
            });
        });

        function renderDetails(item) {
        const imageUrl = (item.imageUrl && item.imageUrl.length > 5)
                         ? "http://localhost:5155" + item.imageUrl
                         : "/images/default.png";
             let catName = item.categoryName || "Kategorisiz";
             let badgeColor = "badge-secondary";

             if (catName.toLowerCase().includes("satılık")) {
                 badgeColor = "badge-danger";
             } else if (catName.toLowerCase().includes("kiralık")) {
                 badgeColor = "badge-success";
             }

             const html = `
                 <div class="row">
                     <div class="col-lg-8">
                         <div class="card shadow-sm border-0 mb-4">
                             <img src="${imageUrl}" class="card-img-top rounded-top" alt="${item.title}" style="max-height: 500px; object-fit: cover;">
                             <div class="card-body p-4">
                                 <h2 class="font-weight-bold text-dark">${item.title}</h2>

                                 <p class="text-muted" style="font-size: 1.1rem;">
                                     <i class="fas fa-map-marker-alt text-danger mr-1"></i>
                                     <strong>Konum:</strong> ${item.cityName || 'Şehir Belirtilmemiş'} / ${item.districtName || 'İlçe Belirtilmemiş'}
                                 </p>

                                 <p class="text-muted" style="font-size: 1.1rem;">
                                     <i class="fas fa-map-signs text-danger mr-1"></i>
                                     <strong>Açık Adres:</strong> <span>${item.address || 'Adres bilgisi girilmemiş.'}</span>
                                 </p>
                                 <hr>

                                 <h4 class="font-weight-bold mt-4 mb-3">İlan Açıklaması</h4>
                                 <p style="font-size: 1.1rem; line-height: 1.8;">${item.description || 'Bu ilan için henüz bir açıklama girilmemiştir.'}</p>
                             </div>
                         </div>
                     </div>

                     <div class="col-lg-4">
                         <div class="card shadow-sm border-0 mb-4 sticky-top" style="top: 20px;">
                             <div class="card-body p-4">
                                 <div class="text-center mb-4">
                                     <span class="badge ${badgeColor} px-3 py-2 mb-2 shadow-sm" style="font-size: 1rem;"><i class="fas fa-tag"></i> ${catName}</span>
                                     <span class="badge badge-info px-3 py-2 mb-2 shadow-sm" style="font-size: 1rem;"><i class="fas fa-home"></i> ${item.propertyType || 'Konut'}</span>

                                     <h1 class="text-success font-weight-bold mt-2">${item.price ? item.price.toLocaleString('tr-TR') : '0'} TL</h1>
                                 </div>

                                 <ul class="list-group list-group-flush mb-4">
                                     <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                         <span class="text-muted"><i class="fas fa-ruler-combined w-20px"></i> Metrekare</span>
                                         <span class="font-weight-bold">${item.squareMeter} m²</span>
                                     </li>
                                     <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                         <span class="text-muted"><i class="fas fa-bed w-20px"></i> Oda Sayısı</span>
                                         <span class="font-weight-bold">${item.roomCount}</span>
                                     </li>
                                     <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                         <span class="text-muted"><i class="fas fa-building w-20px"></i> Bulunduğu Kat</span>
                                         <span class="font-weight-bold">${item.floorLocation}. Kat</span>
                                     </li>
                                     <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                         <span class="text-muted"><i class="fas fa-layer-group w-20px"></i> Bina Kat Sayısı</span>
                                         <span class="font-weight-bold">${item.floorsCount} Katlı</span>
                                     </li>
                                     <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                         <span class="text-muted"><i class="fas fa-fire w-20px"></i> Isıtma</span>
                                         <span class="font-weight-bold">${item.heating}</span>
                                     </li>
                                 </ul>

                                 <button class="btn btn-primary btn-lg btn-block font-weight-bold shadow-sm mb-2" data-toggle="modal" data-target="#messageModal">
                                     <i class="fas fa-envelope"></i> Mesaj Gönder
                                 </button>

                                 <button id="btnFavorite" onclick="addToFavorites()" class="btn btn-outline-danger btn-block font-weight-bold">
                                     <i class="far fa-heart"></i> Favorilere Ekle
                                 </button>
                             </div>
                         </div>
                     </div>
                 </div>
             `;
             $("#detailContainer").html(html);
         }

        function addToFavorites() {
            if (!token) {
                Swal.fire({
                    toast: true,
                    position: 'top-end',
                    showConfirmButton: false,
                    timer: 3000,
                    icon: 'warning',
                    title: 'Oturum Gerekli',
                    text: 'Favorilere eklemek için önce giriş yapmalısınız.'
                });
                setTimeout(() => { window.location.href = "/Auth/Login"; }, 1500);
                return;
            }

            const favoriteData = {
                PropertyId: parseInt(propertyId)
            };

            $.ajax({
                url: apiBaseUrl + "/Favorites",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(favoriteData),
                headers: {
                    "Authorization": "Bearer " + token
                },
                success: function () {
                    Swal.fire({
                        toast: true,
                        position: 'top-end',
                        showConfirmButton: false,
                        timer: 3000,
                        icon: 'success',
                        title: 'Harika!',
                        text: 'İlan favorilerinize eklendi.'
                    });

                    $("#btnFavorite")
                        .removeClass("btn-outline-danger")
                        .addClass("btn-danger text-white")
                        .html('<i class="fas fa-heart"></i> Favorilerinizde');
                },
                error: function (xhr) {
                    Swal.fire({
                        toast: true,
                        position: 'top-end',
                        showConfirmButton: false,
                        timer: 3000,
                        icon: 'info',
                        title: 'Bilgi',
                        text: 'Bu ilan zaten favori listenizde bulunuyor.'
                    });
                }
            });
        }

        function submitMessage() {
             if (!token) {
                 $('#messageModal').modal('hide');
                 Toast.fire({ icon: 'warning', title: 'Uyarı', text: 'Mesaj göndermek için lütfen önce giriş yapın.' });
                 setTimeout(() => { window.location.href = "/Auth/Login"; }, 1500);
                 return;
             }

             const messageData = {
                 ReceiverId: propertyOwnerId,
                 PropertyId: parseInt(propertyId),
                 Text: $("#msgContent").val().trim()
             };

             if (messageData.Text === "") {
                 Toast.fire({ icon: 'warning', title: 'Eksik Bilgi', text: 'Lütfen boş mesaj göndermeyin.' });
                 return;
             }

             $.ajax({
                 url: apiBaseUrl + "/Messages",
                 type: "POST",
                 contentType: "application/json",
                 data: JSON.stringify(messageData),
                 headers: { "Authorization": "Bearer " + token },
                 success: function() {
                     $('#messageModal').modal('hide');
                     $("#msgContent").val("");
                     Toast.fire({ icon: 'success', title: 'Başarılı!', text: 'Mesajınız satıcıya iletildi.' });
                 },
                 error: function(xhr) {
                     Toast.fire({ icon: 'error', title: 'Hata', text: 'Mesaj gönderilemedi.' });
                 }
             });
         }
    </script>
}