@{
    ViewData["Title"] = "İlan Detayı";
}
@{
    Layout = "_UserLayout";
}
<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800" id="detailTitle">Yükleniyor...</h1>
        <a href="/Home/Index" class="btn btn-secondary btn-sm shadow-sm">
            <i class="fas fa-arrow-left fa-sm text-white-50"></i> Vitrine Dön
        </a>
    </div>

    <div class="row">
        <!-- Sol Taraf: Resim ve Açıklama -->
        <div class="col-lg-8">
            <div class="card shadow mb-4">
                <div class="card-body text-center">
                    <img id="detailImage" src="/images/no-image.jpg" class="img-fluid rounded" style="max-height: 400px; width: 100%; object-fit: cover;">
                </div>
            </div>
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">İlan Açıklaması</h6>
                </div>
                <div class="card-body">
                    <p id="detailDescription" class="text-gray-700"></p>
                </div>
            </div>
        </div>

        <!-- Sağ Taraf: Fiyat ve Bilgiler -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-lg sticky-top" style="border-radius: 15px; top: 100px;">
                <div class="card-body p-4">

                    <div class="mb-3">
                        <span class="badge bg-primary px-3 py-2 rounded-pill" id="detailCategory">Kategori</span>
                    </div>

                    <h2 class="text-primary fw-bolder mb-3" id="detailPrice">0 TL</h2>

                    <hr class="text-muted opacity-25" />

                    <div class="mb-3">
                        <i class="fas fa-map-marker-alt text-primary me-2"></i>
                        <span id="detailLocation" class="fw-bold">Şehir / İlçe</span>
                    </div>

                    <div class="mb-4">
                        <i class="fas fa-calendar-alt text-primary me-2"></i>
                        <span class="small text-muted">Yayınlanma: @DateTime.Now.ToString("dd.MM.yyyy")</span>
                    </div>

                    <!-- Senin Satıcıyı Ara Butonun -->
                    <button class="btn btn-success w-100 py-3 rounded-pill fw-bold shadow-sm mb-3">
                        <i class="fas fa-phone-alt me-2"></i> Satıcıyı Ara
                    </button>

                    <!-- Az Önce Yaptığımız Favorilere Ekle Butonu -->
                    <button id="btnFavorite" data-id="1" class="btn btn-outline-danger w-100 py-2 rounded-pill fw-bold">
                        <i class="far fa-heart me-2" id="favIcon"></i> <span id="favText">Favorilere Ekle</span>
                    </button>

                </div>
            </div>
        </div>

@section Scripts {
            <script>
                $(document).ready(function () {

                    // --- 1. BÖLÜM: API'DEN İLAN BİLGİLERİNİ GETİRME ---
                    const apiBaseUrl = "http://localhost:5155/api";

                    // URL'den ID'yi al (Örn: /Properties/Details/5 -> 5'i alır)
                    const urlPath = window.location.pathname;
                    const propertyId = urlPath.split("/").pop();

                    if (propertyId) {
                        $.get(`${apiBaseUrl}/Properties/${propertyId}`, function (data) {
                            // Verileri yerleştir (Case-sensitivity için çift kontrol)
                            const title = data.title || data.Title;
                            const price = data.price || data.Price;
                            const desc = data.description || data.Description;
                            const city = data.cityName || data.CityName;
                            const district = data.districtName || data.DistrictName;
                            const category = data.categoryName || data.CategoryName;

                            $("#detailTitle").text(title);
                            $("#detailDescription").text(desc || "Açıklama belirtilmemiş.");
                            $("#detailPrice").text(price.toLocaleString('tr-TR') + " TL");
                            $("#detailLocation").text(`${city} / ${district}`);
                            $("#detailCategory").text(category);

                        }).fail(function() {
                            alert("İlan detayları getirilemedi!");
                        });
                    }

                    // --- 2. BÖLÜM: FAVORİLERE EKLE BUTONU ANİMASYONU ---
                    $("#btnFavorite").click(function () {
                        var btn = $(this);
                        var icon = $("#favIcon");
                        var text = $("#favText");
                        // data-id değerini URL'den aldığımız gerçek propertyId ile güncelleyebiliriz
                        var currentPropId = propertyId || btn.data("id");

                        // Eğer buton zaten doluysa (yani favorilerdeyse), favorilerden çıkaralım
                        if (btn.hasClass("btn-danger")) {

                            // BURAYA BACKEND SİLME İSTEĞİ GELECEK
                            // $.post('/Properties/RemoveFromFavorites', { id: currentPropId }, function() { ... });

                            // Görseli eski haline çevir
                            btn.removeClass("btn-danger text-white").addClass("btn-outline-danger");
                            icon.removeClass("fas").addClass("far"); // Kalbin içini boşalt
                            text.text("Favorilere Ekle");

                        }
                        // Eğer favorilerde değilse, favorilere ekleyelim
                        else {

                            // BURAYA BACKEND EKLEME İSTEĞİ GELECEK
                            // $.post('/Properties/AddToFavorites', { id: currentPropId }, function() { ... });

                            // Görseli kırmızı yap
                            btn.removeClass("btn-outline-danger").addClass("btn-danger text-white");
                            icon.removeClass("far").addClass("fas"); // Kalbin içini doldur
                            text.text("Favorilerde");
                        }
                    });

                });
            </script>
}
