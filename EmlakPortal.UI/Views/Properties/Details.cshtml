@{
    ViewData["Title"] = "İlan Detayı";
    Layout = "_UserLayout";
}
<div class="container mt-5 mb-5" id="detailContainer">
    <div class="text-center py-5" id="loadingSpinner">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;"></div>
        <h5 class="mt-3 text-muted">İlan detayları yükleniyor...</h5>
    </div>
</div>

@section Scripts {
    <script>
        const apiBaseUrl = "http://localhost:5155/api";
        const propertyId = window.location.pathname.split('/').pop();

        const token = localStorage.getItem("token");

        $(document).ready(function () {
            $.ajax({
                url: apiBaseUrl + "/Properties/" + propertyId,
                type: "GET",
                success: function (data) {
                    renderDetails(data);
                },
                error: function () {
                    $("#detailContainer").html(`<div class="alert alert-danger text-center"><h4><i class="fas fa-exclamation-triangle"></i> İlan bulunamadı veya yayından kaldırılmış.</h4></div>`);
                }
            });
        });

        function renderDetails(item) {
            const imageUrl = item.imageUrl ? item.imageUrl : "/images/default.png";

            const html = `
                <div class="row">
                    <div class="col-lg-8">
                        <div class="card shadow-sm border-0 mb-4">
                            <img src="${imageUrl}" class="card-img-top rounded-top" alt="${item.title}" style="max-height: 500px; object-fit: cover;">
                            <div class="card-body p-4">
                                <h2 class="font-weight-bold text-dark">${item.title}</h2>
                                <p class="text-muted"><i class="fas fa-map-marker-alt text-danger"></i> ${item.cityName || 'Şehir'} / ${item.districtName || 'İlçe'}</p>

                                <hr>

                                <h4 class="font-weight-bold mt-4 mb-3">İlan Açıklaması</h4>
                                <p style="font-size: 1.1rem; line-height: 1.8;">${item.description || 'Bu ilan için henüz bir açıklama girilmemiştir.'}</p>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="card shadow-sm border-0 mb-4 sticky-top" style="top: 20px;">
                            <div class="card-body p-4">
                                <div class="text-center mb-4">
                                    <span class="badge badge-primary px-3 py-2 mb-2" style="font-size: 1rem;">${item.categoryName || 'Emlak'} - ${item.propertyType}</span>
                                    <h1 class="text-success font-weight-bold">${item.price ? item.price.toLocaleString('tr-TR') : '0'} TL</h1>
                                </div>

                                <ul class="list-group list-group-flush mb-4">
                                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                        <span class="text-muted"><i class="fas fa-ruler-combined w-20px"></i> Metrekare</span>
                                        <span class="font-weight-bold">${item.squareMeter} m²</span>
                                    </li>
                                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                        <span class="text-muted"><i class="fas fa-bed w-20px"></i> Oda Sayısı</span>
                                        <span class="font-weight-bold">${item.roomCount}</span>
                                    </li>
                                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                        <span class="text-muted"><i class="fas fa-building w-20px"></i> Bulunduğu Kat</span>
                                        <span class="font-weight-bold">${item.floorLocation}. Kat</span>
                                    </li>
                                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                        <span class="text-muted"><i class="fas fa-layer-group w-20px"></i> Bina Kat Sayısı</span>
                                        <span class="font-weight-bold">${item.floorsCount} Katlı</span>
                                    </li>
                                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                        <span class="text-muted"><i class="fas fa-fire w-20px"></i> Isıtma</span>
                                        <span class="font-weight-bold">${item.heating}</span>
                                    </li>
                                </ul>

                                <button class="btn btn-success btn-lg btn-block font-weight-bold shadow-sm mb-2">
                                    <i class="fas fa-phone-alt"></i> Satıcıyı Ara
                                </button>

                                <button id="btnFavorite" onclick="addToFavorites()" class="btn btn-outline-danger btn-block font-weight-bold">
                                    <i class="far fa-heart"></i> Favorilere Ekle
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            `;
            $("#detailContainer").html(html);
        }

        function addToFavorites() {
             if (!token) {
                 alert("Favorilere eklemek için önce giriş yapmalısınız.");
                 window.location.href = "/Auth/Login";
                 return;
             }

             const favoriteData = {
                 PropertyId: parseInt(propertyId)
             };

             $.ajax({
                 url: apiBaseUrl + "/Favorites", 
                 type: "POST",
                 contentType: "application/json", 
                 data: JSON.stringify(favoriteData), 
                 headers: {
                     "Authorization": "Bearer " + token
                 },
                 success: function () {
                     alert("İlan favorilerinize eklendi!");
                     $("#btnFavorite").removeClass("btn-outline-danger").addClass("btn-danger text-white").html('<i class="fas fa-heart"></i> Favorilerinizde');
                 },
                 error: function (xhr) {
                     alert("Hata: " + xhr.responseText);
                 }
             });
         }
        
    </script>
}