@{
    ViewData["Title"] = "İletişim";
}

<div class="container my-5 py-4">
    <div class="text-center mb-5">
        <span class="text-primary fw-bold text-uppercase small">Bize Ulaşın</span>
        <h2 class="fw-bold display-6 mt-2">Bir Kahve İçmeye Bekleriz</h2>
        <p class="text-muted">Sorularınız, görüşleriniz veya detaylı bilgi almak için bizimle iletişime geçebilirsiniz.</p>
    </div>

    <div class="row g-5">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4 p-md-5">
                    <h4 class="fw-bold mb-4">Mesaj Gönderin</h4>
                    <form>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted">Adınız Soyadınız</label>
                                <input type="text" class="form-control bg-light border-0 py-2" placeholder="Örn: Ahmet Yılmaz">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted">Telefon Numaranız</label>
                                <input type="text" class="form-control bg-light border-0 py-2" placeholder="0555 000 00 00">
                            </div>
                            <div class="col-12">
                                <label class="form-label small fw-bold text-muted">E-Posta Adresiniz</label>
                                <input type="email" class="form-control bg-light border-0 py-2" placeholder="ornek@mail.com">
                            </div>
                            <div class="col-12">
                                <label class="form-label small fw-bold text-muted">Mesajınız</label>
                                <textarea class="form-control bg-light border-0 py-2" rows="5" placeholder="Size nasıl yardımcı olabiliriz?"></textarea>
                            </div>
                            <div class="col-12 mt-4">
                                <button type="button" class="btn btn-primary px-5 py-3 rounded-pill fw-bold w-100">
                                    <i class="fas fa-paper-plane me-2"></i> Mesajı Gönder
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card border-0 shadow-sm rounded-4 bg-primary text-white h-100">
                <div class="card-body p-4 p-md-5">
                    <h4 class="fw-bold mb-4 text-white">İletişim Bilgilerimiz</h4>

                    <div class="d-flex align-items-center mb-4">
                        <div class="bg-white text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                            <i class="fas fa-map-marker-alt fs-5"></i>
                        </div>
                        <div class="ms-3">
                            <h6 class="fw-bold mb-1 text-white">Ofis Adresimiz</h6>
                            <p class="small mb-0 opacity-75">Pınarbaşı Mah. Kampüs İçi,<br>Konyaaltı / Antalya</p>
                        </div>
                    </div>

                    <div class="d-flex align-items-center mb-4">
                        <div class="bg-white text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                            <i class="fas fa-phone-alt fs-5"></i>
                        </div>
                        <div class="ms-3">
                            <h6 class="fw-bold mb-1 text-white">Telefon</h6>
                            <p class="small mb-0 opacity-75">+90 555 123 45 67<br>+90 242 123 45 67</p>
                        </div>
                    </div>

                    <div class="d-flex align-items-center mb-5">
                        <div class="bg-white text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                            <i class="fas fa-envelope fs-5"></i>
                        </div>
                        <div class="ms-3">
                            <h6 class="fw-bold mb-1 text-white">E-Posta</h6>
                            <p class="small mb-0 opacity-75">info@emlakportal.com<br>destek@emlakportal.com</p>
                        </div>
                    </div>

                    <hr class="border-white opacity-25">

                    <div class="mt-4">
                        <h6 class="fw-bold mb-3 text-white">Bizi Takip Edin</h6>
                        <a href="#" class="btn btn-outline-light rounded-circle me-2" style="width: 40px; height: 40px; padding: 7px;"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="btn btn-outline-light rounded-circle me-2" style="width: 40px; height: 40px; padding: 7px;"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="btn btn-outline-light rounded-circle" style="width: 40px; height: 40px; padding: 7px;"><i class="fab fa-twitter"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>