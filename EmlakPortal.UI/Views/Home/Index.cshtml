@{
    ViewData["Title"] = "Ana Sayfa";
}

<style>
    .property-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border-radius: 12px;
        overflow: hidden;
    }

        .property-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }

    .property-badge {
        position: absolute;
        top: 15px;
        right: 15px;
        background: rgba(15, 23, 42, 0.85);
        color: white;
        padding: 5px 15px;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.85rem;
    }

    .price-tag {
        color: #2563eb;
        font-weight: 800;
        font-size: 1.4rem;
    }

    .hero-section {
        background: linear-gradient(135deg, #1e293b 0%, #3b82f6 100%);
        color: white;
        padding: 60px 0 80px 0;
        border-radius: 15px;
        margin-top: 10px;
    }

    .filter-box {
        margin-top: -50px;
        border-radius: 15px;
        position: relative;
        z-index: 10;
    }
</style>

<div class="hero-section text-center shadow">
    <h1 class="fw-bold display-5 mb-3">Hayalinizdeki Evi Keşfedin</h1>
    <p class="lead opacity-75">Binlerce güncel satılık ve kiralık ilan arasından size en uygun olanı bulun.</p>
</div>

<div class="card shadow-lg border-0 filter-box mx-auto w-100" style="max-width: 1000px;">
    <div class="card-body p-4 p-md-5">
        <form id="searchForm" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label fw-bold text-muted small">Anahtar Kelime</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0"><i class="fas fa-search text-muted"></i></span>
                    <input type="text" class="form-control bg-light border-start-0" id="keyword" placeholder="Örn: Dubleks, Bahçeli...">
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold text-muted small">Şehir</label>
                <select class="form-select bg-light" id="citySelect">
                    <option value="">Tüm Şehirler</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold text-muted small">Kategori</label>
                <select class="form-select bg-light" id="categorySelect">
                    <option value="">Tüm Kategoriler</option>
                    <option value="1">Kiralık</option>
                    <option value="2">Satılık</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="button" class="btn btn-primary w-100 py-2 fw-bold" onclick="filterProperties()">
                    <i class="fas fa-filter me-2"></i>Filtrele
                </button>
            </div>
        </form>
    </div>
</div>

<div class="mt-5 pt-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-dark mb-0">Güncel İlanlar</h3>
        <span class="text-muted small" id="resultCount">Yükleniyor...</span>
    </div>

    <div class="row g-4" id="listingsContainer">
        <div class="col-12 text-center py-5" id="loadingSpinner">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
            <p class="mt-2 text-muted">İlanlar getiriliyor...</p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const apiBaseUrl = "http://localhost:5155/api";

        $(document).ready(function () {
            fetchProperties();
            loadFilterCities(); 
        });

        function loadFilterCities() {
            $.ajax({
                url: apiBaseUrl + "/Cities",
                type: "GET",
                success: function (data) {
                    const citySelect = $("#citySelect");
                    citySelect.empty().append('<option value="">Tüm Şehirler</option>');

                    $.each(data, function (index, city) {
                        citySelect.append(`<option value="${city.cityId}">${city.cityName}</option>`);
                    });
                },
                error: function (xhr) {
                    console.error("Şehirler yüklenemedi:", xhr);
                }
            });
        }

        function fetchProperties() {
            showLoading();

            $.ajax({
                url: apiBaseUrl + "/Properties",
                type: "GET",
                success: function (data) {
                    renderListings(data);
                },
                error: function () {
                    showError("İlanlar yüklenirken sunucu ile bağlantı kurulamadı.");

                    Toast.fire({
                        icon: 'error',
                        title: 'Bağlantı Hatası',
                        text: 'İlanlar şu an getirilemiyor.'
                    });
                }
            });
        }

        function filterProperties() {
            const keyword = $("#keyword").val().trim();
            const cityId = $("#citySelect").val();
            const categoryId = $("#categorySelect").val();

            let url = apiBaseUrl + "/Properties/Search?";

            if (keyword) url += "Keyword=" + keyword + "&";
            if (cityId) url += "CityId=" + cityId + "&";
            if (categoryId) url += "CategoryId=" + categoryId + "&";

            if (!keyword && !cityId && !categoryId) {
                fetchProperties();
                return;
            }

            showLoading();

            $.ajax({
                url: url,
                type: "GET",
                success: function (data) {
                    renderListings(data);

                    if (data && data.length > 0) {
                        Toast.fire({
                            icon: 'success',
                            title: 'Arama Tamamlandı',
                            text: `${data.length} adet ilan listelendi.`
                        });
                    } else {
                        Toast.fire({
                            icon: 'info',
                            title: 'Sonuç Bulunamadı',
                            text: 'Farklı kriterler denemeye ne dersiniz?'
                        });
                    }
                },
                error: function (xhr) {
                    if(xhr.status === 404){
                        renderListings([]);
                        Toast.fire({
                            icon: 'info',
                            title: 'Eşleşme Yok',
                            text: 'Aradığınız kriterlerde ilan bulunmuyor.'
                        });
                    } else {
                        showError("Arama yapılırken bir hata oluştu.");
                        Toast.fire({
                            icon: 'error',
                            title: 'Hata',
                            text: 'Arama işlemi gerçekleştirilemedi.'
                        });
                    }
                }
            });
        }

        function renderListings(data) {
            const container = $("#listingsContainer");
            container.empty();

            if (!data || data.length === 0) {
                container.html(`
                    <div class="col-12">
                        <div class="alert alert-info text-center py-4 rounded-3 border-0 shadow-sm">
                            <i class="fas fa-search fa-2x mb-3 text-info opacity-50"></i>
                            <h5 class="fw-bold">Aranan kriterlere uygun ilan bulunamadı.</h5>
                            <p class="mb-0 text-muted">Lütfen filtreleri değiştirerek tekrar deneyin.</p>
                        </div>
                    </div>
                `);
                $("#resultCount").text("0 İlan");
                return;
            }

            $("#resultCount").text(`${data.length} İlan Bulundu`);

            data.forEach(item => {
                const imageUrl = (item.imageUrl && item.imageUrl.length > 5)
                                 ? "http://localhost:5155" + item.imageUrl
                                 : "/images/default.png";

                const cardHtml = `
                    <div class="col-lg-4 col-md-6">
                        <div class="card h-100 border-0 shadow-sm property-card">
                            <div class="position-relative">
                                <img src="${imageUrl}" class="card-img-top" alt="${item.title}" style="height: 220px; object-fit: cover;">
                                <div class="property-badge">${item.categoryName || 'Emlak'}</div>
                            </div>
                            <div class="card-body p-4">
                                <h5 class="card-title fw-bold text-truncate" title="${item.title}">${item.title}</h5>
                                <div class="price-tag mb-3">${item.price ? item.price.toLocaleString('tr-TR') : '0'} ₺</div>
                                <div class="d-flex text-muted small mb-4">
                                    <div class="me-3"><i class="fas fa-map-marker-alt text-primary me-1"></i> ${item.cityName || 'Şehir'} / ${item.districtName || 'İlçe'}</div>
                                </div>
                                <a href="/Properties/Details/${item.propertyId}" class="btn btn-outline-primary w-100 fw-bold rounded-pill">
                                    İlanı İncele <i class="fas fa-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                `;
                container.append(cardHtml);
            });
        }

        function showLoading() {
            $("#listingsContainer").html(`
                <div class="col-12 text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2 text-muted">Yükleniyor...</p>
                </div>
            `);
            $("#resultCount").text("Yükleniyor...");
        }

        function showError(message) {
            $("#listingsContainer").html(`<div class="col-12 text-center text-danger py-5"><i class="fas fa-exclamation-triangle fa-2x mb-3"></i><h5>${message}</h5></div>`);
            $("#resultCount").text("Hata");
        }
    </script>
}