@{
    ViewData["Title"] = "Hakkımızda";
}

<div class="container my-5 py-4">
    <div class="row align-items-center g-5">
        <div class="col-lg-6">
            <div class="position-relative">
                <img src="https://images.unsplash.com/photo-1560518883-ce09059eeffa?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
                     alt="Emlak Ofisimiz" class="img-fluid rounded-4 shadow-lg">
                <div class="position-absolute bottom-0 end-0 bg-primary text-white p-4 rounded-4 shadow" style="transform: translate(20px, 20px);">
                    <h3 class="fw-bold mb-0">15+</h3>
                    <p class="mb-0 small">Yıllık Tecrübe</p>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <span class="text-primary fw-bold text-uppercase tracking-wider small">Kurumsal</span>
            <h2 class="fw-bold display-6 mb-4 mt-2">Hayallerinizdeki Evi Bulmak Artık Çok Daha Kolay</h2>
            <p class="text-muted" style="line-height: 1.8;">
                EmlakPortal olarak, 2011 yılından bu yana binlerce aileyi hayallerindeki yuvayla buluşturmanın gururunu yaşıyoruz. Amacımız sadece gayrimenkul satmak değil, hayatınızın en önemli kararlarından birinde size dürüst ve şeffaf bir rehberlik sunmaktır.
            </p>
            <p class="text-muted" style="line-height: 1.8;">
                Geniş portföyümüz, alanında uzman gayrimenkul danışmanlarımız ve müşteri odaklı hizmet anlayışımızla sektörde fark yaratmaya devam ediyoruz.
            </p>

            <div class="row mt-4 pt-2">
                <div class="col-6">
                    <h5 class="fw-bold"><i class="fas fa-check-circle text-success me-2"></i>Güvenilir</h5>
                    <p class="small text-muted">Şeffaf sözleşmeler ve doğru fiyatlandırma.</p>
                </div>
                <div class="col-6">
                    <h5 class="fw-bold"><i class="fas fa-check-circle text-success me-2"></i>Hızlı</h5>
                    <p class="small text-muted">Geniş ağımızla anında alıcı/satıcı eşleşmesi.</p>
                </div>
            </div>
        </div>
    </div>
</div>