@{
    ViewData["Title"] = "Şehir Yönetimi";
}

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Sistemdeki Şehirler</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Şehir Adı</th>
                    </tr>
                </thead>
                <tbody id="cityList"></tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $.ajax({
                url: "https://localhost:5155/api/Cities", 
                type: "GET",
                success: function (data) {
                    let rows = "";
                    $.each(data, function (i, item) {
                        rows += `<tr><td>${item.cityId}</td><td>${item.cityName}</td></tr>`;
                    });
                    $("#cityList").html(rows);
                }
            });
        });
    </script>
}