@{
    ViewData["Title"] = "Gelen Mesajlar";
    Layout = "~/Views/Shared/_Layout.cshtml"; 
}

<div class="container-fluid mt-4">
    <h1 class="h3 mb-4 text-gray-800"><i class="fas fa-envelope text-primary"></i> Gelen Mesajlar</h1>

    <div class="card shadow mb-4 border-left-primary">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover table-bordered" width="100%" cellspacing="0">
                    <thead class="thead-light">
                        <tr>
                            <th>Tarih</th>
                            <th>Gönderen (Kullanıcı ID)</th>
                            <th>İlan Başlığı</th>
                            <th>Mesaj İçeriği</th>
                            <th>İşlem</th>
                        </tr>
                    </thead>
                    <tbody id="messagesTableBody">
                        <tr><td colspan="5" class="text-center">Mesajlar yükleniyor...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const apiBaseUrl = "http://localhost:5155/api";
        const token = localStorage.getItem("token");

        $(document).ready(function () {
            if (!token) {
                window.location.href = "/Auth/Login";
                return;
            }

            $.ajax({
                url: apiBaseUrl + "/Messages/Inbox",
                type: "GET",
                headers: { "Authorization": "Bearer " + token },
                success: function (data) {
                    let html = "";
                    if (data.length === 0) {
                        html = '<tr><td colspan="5" class="text-center text-muted">Henüz gelen bir mesaj bulunmuyor.</td></tr>';
                    } else {
                        data.forEach(m => {
                            html += `
                                <tr>
                                    <td>${new Date(m.sendDate).toLocaleString('tr-TR')}</td>
                                    <td><span class="badge badge-info">${m.senderId ? m.senderId.substring(0,8) + '...' : 'Bilinmeyen'}</span></td>

                                    <td class="font-weight-bold text-primary">İlan No: #${m.propertyId}</td>

                                    <td>${m.text}</td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i> Sil</button>
                                    </td>
                                </tr>
                            `;
                        });
                    }
                    $("#messagesTableBody").html(html);
                },
                error: function (xhr) {
                    $("#messagesTableBody").html(`<tr><td colspan="5" class="text-center text-danger">Mesajlar yüklenirken hata oluştu: ${xhr.status}</td></tr>`);
                }
            });
       
        });
    </script>
}